{
    "compilerOptions": {
        "checkJs": false,
        "noEmit": true,
        "allowJs": true,
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false
    },
    "include": ["*.js"],
    "exclude": ["node_modules", "html", ".browser-data"]
}
